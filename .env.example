# ─────────────────────────────────────────────────────────────
# AI Provider Configuration
# ─────────────────────────────────────────────────────────────
# Default provider: gemini (free tier available)
AI_PROVIDER=gemini

# Google Gemini (Default — free tier available)
# Get a key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY is the primary name; GOOGLE_API_KEY is accepted as a fallback.
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=

# Optional additional providers (automatic failover)
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ─────────────────────────────────────────────────────────────
# Supabase (Authentication + Database)
# ─────────────────────────────────────────────────────────────
# Create a project: https://supabase.com/dashboard
# Found under Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only key for privileged operations (NEVER expose to the client).
# Found under Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# Stripe (Premium subscriptions) — optional
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_ID=

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
# Public base URL used for auth redirects in production
NEXT_PUBLIC_SITE_URL=http://localhost:3000
